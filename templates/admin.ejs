<%
title = "Waifu TCG Admin";
_%>
<% include includes/header %>

<h1>Admin Panel</h1>
<p>Signed in as <strong><%= adminUser.display_name %></strong> (@<%= adminUser.login %>, ID <%= adminUser.user_id %>).</p>
<p><a class="btn btn-outline-secondary btn-sm" href="/admin-logout">Logout</a></p>
<% if (message) { %>
    <div class="alert alert-info"><%= message %></div>
<% } %>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header">Add Waifu</div>
            <div class="card-body">
                <form method="POST" action="/admin-waifu-add">
                    <div class="form-group">
                        <label>Name</label>
                        <input class="form-control" name="name" required>
                    </div>
                    <div class="form-group">
                        <label>Series</label>
                        <input class="form-control" name="series" required>
                    </div>
                    <div class="form-group">
                        <label>Image URL</label>
                        <input class="form-control" name="image" required>
                    </div>
                    <div class="form-group">
                        <label>Base Rarity</label>
                        <input class="form-control" name="baseRarity" type="number" min="0" max="9" value="0" required>
                    </div>
                    <div class="form-group">
                        <label>Normal Weighting</label>
                        <input class="form-control" name="normalWeighting" type="number" min="0" step="0.0001" value="1" required>
                    </div>
                    <div class="form-group">
                        <label>Event Weighting</label>
                        <input class="form-control" name="eventWeighting" type="number" min="0" step="0.0001" value="1" required>
                    </div>
                    <button class="btn btn-primary" type="submit">Add Waifu</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header">Edit Waifu</div>
            <div class="card-body">
                <form method="GET" action="/admin-waifu-load" class="mb-3">
                    <div class="form-group">
                        <label>Waifu ID</label>
                        <input class="form-control" name="waifuId" type="number" min="1" value="<%= editWaifu.id || '' %>" required>
                    </div>
                    <button class="btn btn-secondary" type="submit">Load</button>
                </form>
                <div class="mb-3">
                    <h6>Search Waifus</h6>
                    <div class="form-row align-items-end">
                        <div class="form-group col-md-5">
                            <label>Name or Series</label>
                            <input class="form-control" id="adminWaifuSearchQuery" type="text" placeholder="e.g. Rem or Re:Zero">
                        </div>
                        <div class="form-group col-md-5">
                            <label>Series (optional)</label>
                            <input class="form-control" id="adminWaifuSearchSeries" type="text" placeholder="Filter by series">
                        </div>
                        <div class="form-group col-md-2">
                            <button class="btn btn-outline-secondary btn-block" id="adminWaifuSearchBtn" type="button">Search</button>
                        </div>
                    </div>
                    <div id="adminWaifuSearchResults" class="small"></div>
                </div>
                <form method="POST" action="/admin-waifu-update">
                    <div class="form-group">
                        <label>Waifu ID</label>
                        <input class="form-control" name="waifuId" type="number" min="1" value="<%= editWaifu.id || '' %>" required>
                    </div>
                    <div class="form-group">
                        <label>Name</label>
                        <input class="form-control" name="name" value="<%= editWaifu.name || '' %>" required>
                    </div>
                    <div class="form-group">
                        <label>Series</label>
                        <input class="form-control" name="series" value="<%= editWaifu.series || '' %>" required>
                    </div>
                    <div class="form-group">
                        <label>Image URL</label>
                        <input class="form-control" name="image" value="<%= editWaifu.image || '' %>" required>
                    </div>
                    <div class="form-group">
                        <label>Base Rarity</label>
                        <input class="form-control" name="baseRarity" type="number" min="0" max="9" value="<%= editWaifu.base_rarity || 0 %>" required>
                    </div>
                    <div class="form-group">
                        <label>Normal Weighting</label>
                        <input class="form-control" name="normalWeighting" type="number" min="0" step="0.0001" value="<%= editWaifu.normal_weighting || 1 %>" required>
                    </div>
                    <div class="form-group">
                        <label>Event Weighting</label>
                        <input class="form-control" name="eventWeighting" type="number" min="0" step="0.0001" value="<%= editWaifu.event_weighting || 1 %>" required>
                    </div>
                    <div class="form-group">
                        <label>Preview Promotion Rarity (visual only)</label>
                        <select class="form-control" name="previewRarity" id="adminWaifuPreviewRaritySelect">
                            <option value="0">0 - common</option>
                            <option value="1">1 - uncommon</option>
                            <option value="2">2 - rare</option>
                            <option value="3">3 - super</option>
                            <option value="4">4 - ultra</option>
                            <option value="5">5 - legendary</option>
                            <option value="6">6 - mythical</option>
                            <option value="7">7 - god</option>
                            <option value="8">8 - special</option>
                            <option value="9">9 - promo</option>
                        </select>
                    </div>
                    <div class="form-group form-check">
                        <input class="form-check-input" type="checkbox" name="previewFirstGod" id="adminWaifuPreviewFirstGod">
                        <label class="form-check-label" for="adminWaifuPreviewFirstGod">Preview as alpha god (visual only)</label>
                    </div>
                    <button class="btn btn-warning" type="submit">Update Waifu</button>
                </form>
                <hr>
                <h6>Card Preview</h6>
                <div class="card card-tcg hand-card" id="adminWaifuPreviewCard" data-cardid="preview">
                    <div class="card-bg-image" id="adminWaifuPreviewBg" style="background-image: url(<%= editWaifu.image || '' %>);"></div>
                    <div class="card-body card-body-tcg">
                        <img src="<%= editWaifu.image || '' %>" alt="Waifu preview" title="Waifu preview" class="card-image" id="adminWaifuPreviewImage" />
                        <div class="id-holder" id="adminWaifuPreviewId"><%= editWaifu.id || '?' %></div>
                        <div class="invisible-space-holder">&nbsp;</div>
                        <div class="rarity-holder" id="adminWaifuPreviewRarityName"><span id="adminWaifuPreviewAlphaPrefix" style="text-transform:none;font-weight:700;display:none">α&thinsp;</span><span id="adminWaifuPreviewRarityText">Rarity</span></div>
                        <div class="promotion-holder" id="adminWaifuPreviewPromotion"></div>
                    </div>
                    <div class="card-footer text-center">
                        <div class="card-info">
                            <span id="adminWaifuPreviewName"><%= editWaifu.name || 'Name' %></span><br />
                            <span id="adminWaifuPreviewSeries"><%= editWaifu.series || 'Series' %></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">Booster Settings (Create / Edit)</div>
    <div class="card-body">
        <div class="mb-3">
            <label class="d-block">Booster List (click to load)</label>
            <div id="adminBoosterList" class="d-flex flex-wrap"></div>
        </div>
        <form method="GET" action="/admin-booster-load" class="mb-3">
            <div class="form-row">
                <div class="form-group col-md-8">
                    <label>Booster Name</label>
                    <input class="form-control" name="name" value="<%= boosterForm.name || '' %>" required>
                </div>
            </div>
            <button class="btn btn-secondary" type="submit">Load</button>
        </form>
        <form method="POST" action="/admin-booster-update">
            <div class="form-row">
                <div class="form-group col-md-4">
                    <label>Booster Name</label>
                    <input class="form-control" name="name" value="<%= boosterForm.name || '' %>" required>
                </div>
                <div class="form-group col-md-4">
                    <label>Sort Index</label>
                    <input class="form-control" name="sortIndex" type="number" min="0" value="<%= boosterForm.sortIndex || 0 %>" required>
                </div>
                <div class="form-group col-md-4">
                    <label>Cost</label>
                    <input class="form-control" name="cost" type="number" min="0" value="<%= boosterForm.cost || 0 %>" required>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group col-md-4">
                    <label>Number of Cards</label>
                    <input class="form-control" name="numCards" type="number" min="1" value="<%= boosterForm.numCards || 1 %>" required>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group col-md-4">
                    <label>Guarantee Rarity</label>
                    <input class="form-control" name="guaranteeRarity" type="number" min="0" max="9" value="<%= boosterForm.guaranteeRarity || 0 %>" required>
                </div>
                <div class="form-group col-md-4">
                    <label>Guarantee Count</label>
                    <input class="form-control" name="guaranteeCount" type="number" min="0" value="<%= boosterForm.guaranteeCount || 0 %>" required>
                </div>
                <div class="form-group col-md-4">
                    <label>Max Event Tokens</label>
                    <input class="form-control" name="maxEventTokens" type="number" min="0" value="<%= boosterForm.maxEventTokens || 0 %>" required>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group col-md-4">
                    <label>Event Token Chance</label>
                    <input class="form-control" name="eventTokenChance" type="number" min="0" max="1" step="0.0001" value="<%= boosterForm.eventTokenChance || 0 %>" required>
                </div>
                <div class="form-group col-md-8">
                    <label>Guaranteed Rarity Slots (optional, comma-separated)</label>
                    <input class="form-control" name="guaranteedRaritySlots" value="<%= boosterForm.guaranteedRaritySlots || '' %>" placeholder="e.g. 2,3,5">
                    <small class="form-text text-muted">If set, this booster forces exactly one card for each listed base rarity ID (when enough cards can be generated).</small>
                </div>
                <% boosterUpgradeColumns.forEach(function (column) { %>
                    <div class="form-group col-md-4">
                        <label><%= column %></label>
                        <input class="form-control" name="<%= column %>" type="number" min="0" max="1" step="any" value="<%= boosterForm.rarityChances[column] || 1 %>" required>
                    </div>
                <% }) %>
            </div>
            <div class="form-row">
                <div class="form-group col-md-2">
                    <label>Listed</label>
                    <select class="form-control" name="listed">
                        <option value="0" <%= boosterForm.listed ? '' : 'selected' %>>No</option>
                        <option value="1" <%= boosterForm.listed ? 'selected' : '' %>>Yes</option>
                    </select>
                </div>
                <div class="form-group col-md-2">
                    <label>Buyable</label>
                    <select class="form-control" name="buyable">
                        <option value="0" <%= boosterForm.buyable ? '' : 'selected' %>>No</option>
                        <option value="1" <%= boosterForm.buyable ? 'selected' : '' %>>Yes</option>
                    </select>
                </div>
                <div class="form-group col-md-3">
                    <label>Use Event Weightings</label>
                    <select class="form-control" name="useEventWeightings">
                        <option value="0" <%= boosterForm.useEventWeightings ? '' : 'selected' %>>No</option>
                        <option value="1" <%= boosterForm.useEventWeightings ? 'selected' : '' %>>Yes</option>
                    </select>
                </div>
                <div class="form-group col-md-2">
                    <label>Can Mega</label>
                    <select class="form-control" name="canMega">
                        <option value="0" <%= boosterForm.canMega ? '' : 'selected' %>>No</option>
                        <option value="1" <%= boosterForm.canMega ? 'selected' : '' %>>Yes</option>
                    </select>
                </div>
                <div class="form-group col-md-3">
                    <label>Apply Scaling</label>
                    <select class="form-control" name="applyScaling">
                        <option value="0" <%= boosterForm.applyScaling ? '' : 'selected' %>>No</option>
                        <option value="1" <%= boosterForm.applyScaling ? 'selected' : '' %>>Yes</option>
                    </select>
                </div>
            </div>
            <button class="btn btn-info" type="submit">Save Booster</button>
        </form>
        <hr>
        <h6>Booster Test Preview</h6>
        <div class="form-row align-items-end">
            <div class="form-group col-md-4">
                <label>Opened Packs</label>
                <div class="input-group">
                    <input id="boosterTestPackCount" class="form-control" type="number" min="1" max="10000" step="1" value="100">
                    <div class="input-group-append">
                        <button id="boosterTestReroll" class="btn btn-outline-secondary" type="button">Reroll</button>
                    </div>
                </div>
            </div>
            <div class="form-group col-md-8 text-md-right">
                <div class="h4 mb-2">Estimated Total Cost: <span id="boosterTestTotalCost">0</span></div>
                <div class="h4 mb-2">Estimated Disenchant Total: <span id="boosterTestDisenchantTotal">0</span></div>
                <div class="h4 mb-2">Cost - Disenchant: <span id="boosterTestProfitDelta" class="font-weight-bold">0</span></div>
                <small class="text-muted">Updates live from current form settings.</small>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-bordered" id="boosterTestResultsTable">
                <thead>
                <tr>
                    <th>Rarity</th>
                    <th>Cards</th>
                    <th>Disenchant Value / Card</th>
                    <th>Total Disenchant</th>
                </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mb-3 border-danger">
    <div class="card-header text-danger">One-Click Event Close</div>
    <div class="card-body">
        <p class="mb-2">
            This will:
            <strong>(1)</strong> set all event waifus to <code>promo</code>,
            <strong>(2)</strong> set one listed booster to unlisted + unbuyable,
            <strong>(3)</strong> trigger the Python bot reload.
        </p>
        <button class="btn btn-danger" id="oneClickEventCloseBtn" type="button">Run One-Click Event Close</button>
        <div class="mt-2 text-muted" id="oneClickEventCloseStatus"></div>
    </div>
</div>

<script>
    (function () {
        const adminBoosterList = document.getElementById('adminBoosterList');
        const boosterNameInput = document.querySelector('form[action="/admin-booster-load"] input[name="name"]');
        const boosterLoadForm = document.querySelector('form[action="/admin-booster-load"]');
        const boosterUpdateForm = document.querySelector('form[action="/admin-booster-update"]');
        const testPackCountInput = document.getElementById('boosterTestPackCount');
        const testRerollButton = document.getElementById('boosterTestReroll');
        const testTotalCostEl = document.getElementById('boosterTestTotalCost');
        const testDisenchantTotalEl = document.getElementById('boosterTestDisenchantTotal');
        const testProfitDeltaEl = document.getElementById('boosterTestProfitDelta');
        const testResultsBody = document.querySelector('#boosterTestResultsTable tbody');
        const waifuSearchQuery = document.getElementById('adminWaifuSearchQuery');
        const waifuSearchSeries = document.getElementById('adminWaifuSearchSeries');
        const waifuSearchButton = document.getElementById('adminWaifuSearchBtn');
        const waifuSearchResults = document.getElementById('adminWaifuSearchResults');
        const rarityNameMap = {
            0: 'common',
            1: 'uncommon',
            2: 'rare',
            3: 'super',
            4: 'ultra',
            5: 'legendary',
            6: 'mythical',
            7: 'god',
            8: 'special',
            9: 'promo'
        };
        const rarityValueMap = {
            0: <%= parseInt(config.rarity0Value || 0, 10) %>,
            1: <%= parseInt(config.rarity1Value || 0, 10) %>,
            2: <%= parseInt(config.rarity2Value || 0, 10) %>,
            3: <%= parseInt(config.rarity3Value || 0, 10) %>,
            4: <%= parseInt(config.rarity4Value || 0, 10) %>,
            5: <%= parseInt(config.rarity5Value || 0, 10) %>,
            6: <%= parseInt(config.rarity6Value || 0, 10) %>,
            7: <%= parseInt(config.rarity7Value || 0, 10) %>,
            8: <%= parseInt(config.rarity8Value || 0, 10) %>,
            9: <%= parseInt(config.rarity9Value || 0, 10) %>
        };
        const upgradeColumns = [<% boosterUpgradeColumns.forEach(function (column, idx) { %><%= idx ? ', ' : '' %>'<%= column %>'<% }) %>];
        const maxConfiguredBoosterRarity = Math.max(0, Math.min(9, upgradeColumns.length - 1));
        const parsedMinScalingRarity = parseInt('<%= parseInt(config.pullScalingMinRarity || 0, 10) %>', 10);
        const parsedMaxScalingRarity = parseInt('<%= parseInt(config.pullScalingMaxRarity || 0, 10) %>', 10);
        const minScalingRarity = Math.max(0, Math.min(maxConfiguredBoosterRarity, Number.isFinite(parsedMinScalingRarity) ? parsedMinScalingRarity : 0));
        const maxScalingRarity = Math.max(minScalingRarity, Math.min(maxConfiguredBoosterRarity, Number.isFinite(parsedMaxScalingRarity) ? parsedMaxScalingRarity : minScalingRarity));
        const numNormalRarities = Math.max(1, Math.min(10, parseInt('<%= parseInt(config.numNormalRarities || 10, 10) %>', 10) || 10));
        const scalingThresholdMap = {
            0: <%= parseInt(config.pullScalingRarity0Threshold || 0, 10) %>,
            1: <%= parseInt(config.pullScalingRarity1Threshold || 0, 10) %>,
            2: <%= parseInt(config.pullScalingRarity2Threshold || 0, 10) %>,
            3: <%= parseInt(config.pullScalingRarity3Threshold || 0, 10) %>,
            4: <%= parseInt(config.pullScalingRarity4Threshold || 0, 10) %>,
            5: <%= parseInt(config.pullScalingRarity5Threshold || 0, 10) %>,
            6: <%= parseInt(config.pullScalingRarity6Threshold || 0, 10) %>,
            7: <%= parseInt(config.pullScalingRarity7Threshold || 0, 10) %>,
            8: <%= parseInt(config.pullScalingRarity8Threshold || 0, 10) %>,
            9: <%= parseInt(config.pullScalingRarity9Threshold || 0, 10) %>
        };
        const scalingThresholds = [];
        for (let rarity = minScalingRarity; rarity <= maxScalingRarity; rarity++) {
            scalingThresholds.push(parseInt(scalingThresholdMap[rarity], 10) || 0);
        }

        function makeStatusPill(text, className) {
            const span = document.createElement('span');
            span.className = 'badge badge-pill ml-1 ' + className;
            span.textContent = text;
            return span;
        }

        function loadBoosterList() {
            if (!adminBoosterList) {
                return;
            }
            fetch('/admin-boosters', {credentials: 'same-origin'})
                .then((response) => {
                    if (!response.ok) {
                        throw new Error('Could not load booster list.');
                    }
                    return response.json();
                })
                .then((data) => {
                    adminBoosterList.innerHTML = '';
                    const boosters = data && Array.isArray(data.boosters) ? data.boosters : [];
                    if (!boosters.length) {
                        adminBoosterList.textContent = 'No boosters found.';
                        return;
                    }
                    boosters.forEach((booster) => {
                        const button = document.createElement('button');
                        button.type = 'button';
                        button.className = 'btn btn-outline-secondary btn-sm mr-2 mb-2';
                        button.textContent = booster.name;
                        button.appendChild(makeStatusPill('Listed', booster.listed ? 'badge-success' : 'badge-secondary'));
                        button.appendChild(makeStatusPill('Buyable', booster.buyable ? 'badge-primary' : 'badge-secondary'));
                        button.addEventListener('click', () => {
                            if (boosterNameInput) {
                                boosterNameInput.value = booster.name;
                            }
                            if (boosterLoadForm) {
                                boosterLoadForm.submit();
                            }
                        });
                        adminBoosterList.appendChild(button);
                    });
                })
                .catch((err) => {
                    adminBoosterList.innerHTML = '<span class="text-danger">' + (err && err.message ? err.message : 'Failed to load boosters.') + '</span>';
                });
        }

        function parseNumberInput(form, name, fallback) {
            if (!form) {
                return fallback;
            }
            const field = form.querySelector('[name="' + name + '"]');
            const value = field ? parseFloat(field.value) : fallback;
            return Number.isFinite(value) ? value : fallback;
        }

        function buildRarityTableRows(cardsByRarity, pityCardsByRarity, totalCost) {
            if (!testResultsBody) {
                return;
            }
            testResultsBody.innerHTML = '';
            let totalValue = 0;
            Object.keys(cardsByRarity).map((k) => parseInt(k, 10)).sort((a, b) => a - b).forEach((rarity) => {
                const cards = cardsByRarity[rarity] || 0;
                const pityCards = pityCardsByRarity[rarity] || 0;
                const perCard = rarityValueMap[rarity] || 0;
                const total = cards * perCard;
                totalValue += total;
                const row = document.createElement('tr');
                row.innerHTML = '<td>' + (rarityNameMap[rarity] || ('rarity ' + rarity)) + '</td>' +
                    '<td>' + cards + (pityCards > 0 ? ' <span class="badge badge-warning" title="Cards from pity/scaling floor">(' + pityCards + ' pity)</span>' : '') + '</td>' +
                    '<td>' + perCard + '</td>' +
                    '<td><strong>' + total + '</strong></td>';
                testResultsBody.appendChild(row);
            });
            if (testTotalCostEl) {
                testTotalCostEl.textContent = String(totalCost);
            }
            if (testDisenchantTotalEl) {
                testDisenchantTotalEl.textContent = String(totalValue);
            }
            if (testProfitDeltaEl) {
                const delta = totalCost - totalValue;
                const profitable = delta < 0;
                testProfitDeltaEl.textContent = String(delta) + (profitable ? ' (profitable)' : ' (not profitable)');
                testProfitDeltaEl.classList.remove('text-danger', 'text-success');
                testProfitDeltaEl.classList.add(profitable ? 'text-danger' : 'text-success');
            }
        }

        function popForcedRarityFromList(rarities, minRarity) {
            if (!rarities || !rarities.length) {
                return null;
            }
            for (let i = 0; i < rarities.length; i++) {
                if (rarities[i] >= minRarity) {
                    return rarities.splice(i, 1)[0];
                }
            }
            return null;
        }

        function buildScaledUpgradeChances(normalChances, scalingData) {
            const currentChances = normalChances.slice();
            let guaranteedRarity = 0;
            for (let rarity = maxScalingRarity; rarity >= minScalingRarity; rarity--) {
                const scaleIdx = rarity - minScalingRarity;
                const threshold = scalingThresholds[scaleIdx] || 0;
                if (threshold <= 0) {
                    continue;
                }
                if (scalingData[scaleIdx] >= threshold * 2) {
                    if (rarity === numNormalRarities - 1) {
                        for (let i = 0; i < currentChances.length; i++) {
                            currentChances[i] = 1;
                        }
                    } else if (rarity > 0 && rarity < currentChances.length) {
                        let cumulative = 1;
                        for (let i = 0; i <= rarity; i++) {
                            cumulative *= currentChances[i];
                        }
                        for (let i = 0; i < rarity; i++) {
                            currentChances[i] = 1;
                        }
                        currentChances[rarity] = cumulative;
                    }
                    guaranteedRarity = rarity;
                    break;
                }
                if (scalingData[scaleIdx] > threshold && rarity > 0 && rarity < currentChances.length) {
                    const oldPromoChance = currentChances[rarity - 1];
                    const scaledChance = Math.min(currentChances[rarity - 1] * (((scalingData[scaleIdx] / threshold - 1) * 2) + 1), 1);
                    currentChances[rarity - 1] = scaledChance;
                    if (rarity !== numNormalRarities - 1 && currentChances[rarity - 1] > 0 && oldPromoChance > 0) {
                        currentChances[rarity] /= currentChances[rarity - 1] / oldPromoChance;
                    }
                }
            }
            return {currentChances, guaranteedRarity};
        }

        function simulateBoosterResults() {
            if (!boosterUpdateForm || !testPackCountInput) {
                return;
            }
            const packCount = Math.max(1, Math.min(10000, parseInt(testPackCountInput.value || '1', 10) || 1));
            const numCards = Math.max(1, parseInt(parseNumberInput(boosterUpdateForm, 'numCards', 1), 10));
            const maxEventTokens = Math.max(0, parseInt(parseNumberInput(boosterUpdateForm, 'maxEventTokens', 0), 10));
            const eventTokenChance = Math.max(0, Math.min(1, parseNumberInput(boosterUpdateForm, 'eventTokenChance', 0)));
            const guaranteeRarity = Math.max(0, Math.min(9, parseInt(parseNumberInput(boosterUpdateForm, 'guaranteeRarity', 0), 10)));
            const guaranteeCount = Math.max(0, parseInt(parseNumberInput(boosterUpdateForm, 'guaranteeCount', 0), 10));
            const cost = Math.max(0, parseInt(parseNumberInput(boosterUpdateForm, 'cost', 0), 10));
            const listed = parseInt(parseNumberInput(boosterUpdateForm, 'listed', 0), 10) !== 0;
            const buyable = parseInt(parseNumberInput(boosterUpdateForm, 'buyable', 0), 10) !== 0;
            const applyScaling = parseInt(parseNumberInput(boosterUpdateForm, 'applyScaling', 0), 10) !== 0;
            const forcedRaritiesRaw = String((boosterUpdateForm.querySelector('[name="guaranteedRaritySlots"]') || {}).value || '');
            const forcedRarities = [];
            const seen = {};
            forcedRaritiesRaw.split(',').forEach((raw) => {
                const parsed = parseInt(String(raw).trim(), 10);
                if (!Number.isFinite(parsed) || parsed < 0 || parsed > 9 || seen[parsed]) {
                    return;
                }
                seen[parsed] = true;
                forcedRarities.push(parsed);
            });
            const normalChances = upgradeColumns.map((column) => {
                const value = parseNumberInput(boosterUpdateForm, column, 1);
                return Math.max(0, Math.min(1, value));
            });
            const scalingData = [];
            for (let i = 0; i <= (maxScalingRarity - minScalingRarity); i++) {
                scalingData.push(0);
            }
            const cardsByRarity = {};
            const pityCardsByRarity = {};
            for (let rarity = 0; rarity <= 9; rarity++) {
                cardsByRarity[rarity] = 0;
                pityCardsByRarity[rarity] = 0;
            }

            for (let pack = 0; pack < packCount; pack++) {
                let tokenCount = 0;
                for (let t = 0; t < maxEventTokens; t++) {
                    if (Math.random() < eventTokenChance) {
                        tokenCount++;
                    }
                }
                let normalSlots = Math.max(0, numCards - tokenCount);
                let forcedQueue = forcedRarities.slice(0, normalSlots);
                let guaranteedSlots = Math.min(guaranteeCount, normalSlots);
                for (let i = 0; i < normalSlots; i++) {
                    let effectiveChances = normalChances.slice();
                    let scalingGuaranteedRarity = 0;
                    if (listed && buyable && applyScaling) {
                        const scaled = buildScaledUpgradeChances(normalChances, scalingData);
                        effectiveChances = scaled.currentChances;
                        scalingGuaranteedRarity = scaled.guaranteedRarity;
                    }

                    if (i < guaranteedSlots && guaranteeRarity > scalingGuaranteedRarity) {
                        if (guaranteeRarity === numNormalRarities - 1) {
                            for (let j = 0; j < effectiveChances.length; j++) {
                                effectiveChances[j] = 1;
                            }
                        } else if (guaranteeRarity > 0 && guaranteeRarity < effectiveChances.length) {
                            let cumulative = 1;
                            for (let j = 0; j <= guaranteeRarity; j++) {
                                cumulative *= effectiveChances[j];
                            }
                            for (let j = 0; j < guaranteeRarity; j++) {
                                effectiveChances[j] = 1;
                            }
                            effectiveChances[guaranteeRarity] = cumulative;
                        }
                    }

                    const minRarity = i < guaranteedSlots ? guaranteeRarity : scalingGuaranteedRarity;
                    const forcedRarity = popForcedRarityFromList(forcedQueue, minRarity);
                    let rarity = forcedRarity;
                    if (rarity === null) {
                        rarity = 0;
                        while (rarity < effectiveChances.length && Math.random() < effectiveChances[rarity]) {
                            rarity++;
                        }
                    }
                    if (guaranteedSlots > 0) {
                        guaranteedSlots--;
                    }
                    rarity = Math.max(0, Math.min(9, rarity));
                    cardsByRarity[rarity]++;
                    if (scalingGuaranteedRarity > 0 && rarity === scalingGuaranteedRarity) {
                        pityCardsByRarity[rarity]++;
                    }
                    if (listed && buyable && applyScaling) {
                        for (let r = minScalingRarity; r <= maxScalingRarity; r++) {
                            const idx = r - minScalingRarity;
                            if (r !== rarity) {
                                scalingData[idx] += cost / Math.max(1, normalSlots);
                            } else {
                                scalingData[idx] = 0;
                            }
                        }
                    }
                }
            }
            buildRarityTableRows(cardsByRarity, pityCardsByRarity, cost * packCount);
        }

        function updateWaifuPreviewRarityClasses(rarity, firstGod) {
            const card = document.getElementById('adminWaifuPreviewCard');
            const idHolder = document.getElementById('adminWaifuPreviewId');
            const rarityHolder = document.getElementById('adminWaifuPreviewRarityName');
            const promotionHolder = document.getElementById('adminWaifuPreviewPromotion');
            if (!card || !idHolder || !rarityHolder || !promotionHolder) {
                return;
            }
            Object.keys(rarityNameMap).forEach((key) => {
                const rarityName = rarityNameMap[key];
                card.classList.remove('card-' + rarityName);
                idHolder.classList.remove('rarity-' + rarityName);
                rarityHolder.classList.remove('rarity-' + rarityName);
                promotionHolder.classList.remove('rarity-' + rarityName);
            });
            card.classList.remove('card-firstgod');
            idHolder.classList.remove('rarity-firstgod');
            rarityHolder.classList.remove('rarity-firstgod');
            promotionHolder.classList.remove('rarity-firstgod');
            const rarityName = rarityNameMap[rarity] || 'common';
            const appliedRarityClass = firstGod ? 'firstgod' : rarityName;
            card.classList.add('card-' + appliedRarityClass);
            idHolder.classList.add('rarity-' + appliedRarityClass);
            rarityHolder.classList.add('rarity-' + appliedRarityClass);
            promotionHolder.classList.add('rarity-' + appliedRarityClass);
            const rarityText = document.getElementById('adminWaifuPreviewRarityText');
            if (rarityText) {
                rarityText.textContent = rarityName;
            }
        }

        function wireWaifuPreview() {
            const editForm = document.querySelector('form[action="/admin-waifu-update"]');
            if (!editForm) {
                return;
            }
            const map = {
                waifuId: document.getElementById('adminWaifuPreviewId'),
                name: document.getElementById('adminWaifuPreviewName'),
                series: document.getElementById('adminWaifuPreviewSeries'),
                image: document.getElementById('adminWaifuPreviewImage'),
                baseRarity: document.getElementById('adminWaifuPreviewRarityName'),
                promotion: document.getElementById('adminWaifuPreviewPromotion'),
                alphaPrefix: document.getElementById('adminWaifuPreviewAlphaPrefix')
            };
            function sync() {
                const idField = editForm.querySelector('[name="waifuId"]');
                const nameField = editForm.querySelector('[name="name"]');
                const seriesField = editForm.querySelector('[name="series"]');
                const imageField = editForm.querySelector('[name="image"]');
                const rarityField = editForm.querySelector('[name="baseRarity"]');
                const previewRarityField = editForm.querySelector('[name="previewRarity"]');
                const previewFirstGodField = editForm.querySelector('[name="previewFirstGod"]');
                if (map.waifuId && idField) {
                    map.waifuId.textContent = idField.value || '?';
                }
                if (map.name && nameField) {
                    map.name.textContent = nameField.value || 'Name';
                }
                if (map.series && seriesField) {
                    map.series.textContent = seriesField.value || 'Series';
                }
                if (imageField) {
                    const imageUrl = imageField.value || '';
                    const bg = document.getElementById('adminWaifuPreviewBg');
                    if (map.image) {
                        map.image.src = imageUrl;
                    }
                    if (bg) {
                        bg.style.backgroundImage = imageUrl ? 'url(' + imageUrl + ')' : '';
                    }
                }
                const baseRarity = Math.max(0, Math.min(9, parseInt((rarityField && rarityField.value) || '0', 10) || 0));
                let rarity = baseRarity;
                if (previewRarityField) {
                    rarity = Math.max(baseRarity, Math.min(9, parseInt(previewRarityField.value || '0', 10) || baseRarity));
                    previewRarityField.value = String(rarity);
                }
                const previewFirstGod = !!(previewFirstGodField && previewFirstGodField.checked);
                updateWaifuPreviewRarityClasses(rarity, previewFirstGod);
                if (map.promotion) {
                    map.promotion.textContent = rarity > baseRarity && rarity < 8 ? '★'.repeat(rarity - baseRarity) : '';
                }
                if (map.alphaPrefix) {
                    map.alphaPrefix.style.display = previewFirstGod ? 'inline' : 'none';
                }
            }
            editForm.addEventListener('input', sync);
            const previewRaritySelect = editForm.querySelector('[name="previewRarity"]');
            if (previewRaritySelect) {
                const initialBaseRarity = Math.max(0, Math.min(9, parseInt((editForm.querySelector('[name="baseRarity"]') || {}).value || '0', 10) || 0));
                previewRaritySelect.value = String(initialBaseRarity);
            }
            sync();
        }

        function renderWaifuSearchResults(waifus) {
            if (!waifuSearchResults) {
                return;
            }
            waifuSearchResults.innerHTML = '';
            if (!waifus || !waifus.length) {
                waifuSearchResults.textContent = 'No waifus found.';
                return;
            }
            const listGroup = document.createElement('div');
            listGroup.className = 'list-group';
            waifus.forEach((waifu) => {
                const item = document.createElement('button');
                item.type = 'button';
                item.className = 'list-group-item list-group-item-action d-flex justify-content-between align-items-center';
                item.innerHTML = '<span><strong>#' + waifu.id + '</strong> ' + (waifu.name || '') + ' <span class="text-muted">(' + (waifu.series || 'Unknown series') + ')</span></span>' +
                    '<span class="badge badge-secondary badge-pill">' + (rarityNameMap[waifu.baseRarity] || 'unknown') + '</span>';
                item.addEventListener('click', () => {
                    window.location.href = '/admin-waifu-load?waifuId=' + encodeURIComponent(String(waifu.id || ''));
                });
                listGroup.appendChild(item);
            });
            waifuSearchResults.appendChild(listGroup);
        }

        async function runWaifuSearch() {
            if (!waifuSearchResults) {
                return;
            }
            const query = waifuSearchQuery ? waifuSearchQuery.value.trim() : '';
            const series = waifuSearchSeries ? waifuSearchSeries.value.trim() : '';
            if (!query && !series) {
                waifuSearchResults.textContent = 'Enter a search term first.';
                return;
            }
            waifuSearchResults.textContent = 'Searching...';
            try {
                const params = new URLSearchParams();
                if (query) {
                    params.set('q', query);
                }
                if (series) {
                    params.set('series', series);
                }
                params.set('limit', '50');
                const response = await fetch('/admin-waifu-search?' + params.toString(), {credentials: 'same-origin'});
                if (!response.ok) {
                    throw new Error('Could not search waifus.');
                }
                const data = await response.json();
                renderWaifuSearchResults(Array.isArray(data.waifus) ? data.waifus : []);
            } catch (err) {
                waifuSearchResults.textContent = err && err.message ? err.message : 'Could not search waifus.';
            }
        }

        if (boosterUpdateForm) {
            boosterUpdateForm.addEventListener('input', simulateBoosterResults);
        }
        if (testPackCountInput) {
            testPackCountInput.addEventListener('input', simulateBoosterResults);
        }
        if (testRerollButton) {
            testRerollButton.addEventListener('click', simulateBoosterResults);
        }
        if (waifuSearchButton) {
            waifuSearchButton.addEventListener('click', runWaifuSearch);
        }
        if (waifuSearchQuery) {
            waifuSearchQuery.addEventListener('keydown', (event) => {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    runWaifuSearch();
                }
            });
        }
        if (waifuSearchSeries) {
            waifuSearchSeries.addEventListener('keydown', (event) => {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    runWaifuSearch();
                }
            });
        }
        loadBoosterList();
        simulateBoosterResults();
        wireWaifuPreview();

        const btn = document.getElementById('oneClickEventCloseBtn');
        const status = document.getElementById('oneClickEventCloseStatus');
        if (!btn || !status) {
            return;
        }

        function setStatus(message, isError) {
            status.textContent = message || '';
            status.className = isError ? 'mt-2 text-danger' : 'mt-2 text-success';
        }

        async function fetchListedBoosters() {
            const response = await fetch('/admin-listed-boosters', {credentials: 'same-origin'});
            if (!response.ok) {
                throw new Error('Could not load listed boosters.');
            }
            const data = await response.json();
            return Array.isArray(data.boosters) ? data.boosters : [];
        }

        async function runEventClose(boosterName, allowPromotedCopies) {
            const payload = new URLSearchParams();
            payload.set('boosterName', boosterName);
            payload.set('allowPromotedCopies', allowPromotedCopies ? '1' : '0');
            const response = await fetch('/admin-event-close', {
                method: 'POST',
                credentials: 'same-origin',
                headers: {'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'},
                body: payload.toString()
            });
            const text = await response.text();
            let data = {};
            try {
                data = text ? JSON.parse(text) : {};
            } catch (e) {
                data = {};
            }
            return {response, data, rawText: text};
        }

        btn.addEventListener('click', async () => {
            btn.disabled = true;
            setStatus('Loading listed boosters...', false);
            try {
                const boosters = await fetchListedBoosters();
                if (!boosters.length) {
                    throw new Error('No currently listed boosters were found.');
                }
                const chosen = window.prompt(
                    'Pick booster to set unlisted+unbuyable:\n\n' + boosters.join('\n'),
                    boosters[0]
                );
                if (chosen === null) {
                    setStatus('Cancelled.', false);
                    return;
                }
                const selected = String(chosen).trim();
                if (!selected) {
                    throw new Error('No booster selected.');
                }

                setStatus('Applying one-click event close...', false);
                let result = await runEventClose(selected, false);
                if (result.response.status === 409 && result.data && result.data.requiresConfirmation) {
                    const confirmed = window.confirm((result.data.message || 'Some event waifus are already promoted. Continue?') + '\n\nThis may affect already-promoted event waifus.');
                    if (!confirmed) {
                        setStatus('Cancelled after promoted-waifu warning.', false);
                        return;
                    }
                    result = await runEventClose(selected, true);
                }

                if (!result.response.ok) {
                    throw new Error(result.data && result.data.message ? result.data.message : (result.rawText || 'Operation failed.'));
                }
                setStatus((result.data && result.data.message) || 'One-click event close completed.', false);
            } catch (err) {
                setStatus(err && err.message ? err.message : 'Operation failed.', true);
            } finally {
                btn.disabled = false;
            }
        });
    })();
</script>

